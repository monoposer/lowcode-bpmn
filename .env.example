# Copy to .env and adjust values:
#   cp .env.example .env

# HTTP listen address (inside container use :8080)
HTTP_ADDR=:8080

# Store backend: db | file | memory
STORE_BACKEND=db

# File store directory (used when STORE_BACKEND=file)
STORE_PATH=./data

# Database driver: postgres | mysql | sqlite (used when STORE_BACKEND=db)
DB_DRIVER=postgres

# PostgreSQL (docker-compose default)
DATABASE_URL=postgres://lowcode:lowcode@postgres:5432/lowcode_bpmn?sslmode=disable

# MySQL example
# DB_DRIVER=mysql
# DATABASE_URL=lowcode:lowcode@tcp(mysql:3306)/lowcode_bpmn?charset=utf8mb4&parseTime=True&loc=Local

# SQLite example (local dev, STORE_BACKEND=db)
# DB_DRIVER=sqlite
# DATABASE_URL=file:/data/lowcode.db?cache=shared&_pragma=foreign_keys(1)

# File store example (YAML persistence, no database required)
# STORE_BACKEND=file
# STORE_PATH=./data

# Enable background worker for async start/continue jobs
ASYNC_EXECUTION=true

# Worker poll interval
WORKER_INTERVAL=500ms

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# OpenTelemetry (set OTEL_ENABLED=true and point to a collector)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=lowcode-bpmn
SERVICE_VERSION=dev
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- docker-compose only (postgres service) ---
POSTGRES_USER=lowcode
POSTGRES_PASSWORD=lowcode
POSTGRES_DB=lowcode_bpmn

# Host port mapping for the API
APP_PORT=8080

# --- Event plugin runtime (see docs/plugins.md) ---
EVENT_CONSUMER=memory
# EVENT_CONSUMER=redis
# EVENT_REDIS_URL=redis://redis:6379/0
# EVENT_REDIS_ASSIGNEE_KEY=bpmn:events:assignee
# EVENT_REDIS_TRIGGER_KEY=bpmn:events:trigger
# EVENT_REDIS_TASK_KEY=bpmn:events:task
# EVENT_REDIS_CONTROL_KEY=bpmn:events:control

PLUGIN_ASSIGNEE_ADAPTERS=generic,canonical,feishu,wecom
PLUGIN_TRIGGER_ADAPTERS=generic,canonical,feishu,wecom,airtable
PLUGIN_TASK_ADAPTERS=generic,canonical,feishu,wecom
PLUGIN_CONTROL_ADAPTERS=generic,canonical
PLUGIN_DEFAULT_TENANT=demo
# PLUGIN_WASM_DIR=./plugins/wasm

# --- API authentication (recommended for production) ---
# AUTH_REQUIRED=true
# API_KEY=change-me
# API_KEYS=demo:tenant-key-1,ops:tenant-key-2

# --- Production HA: Redis event transport + OTEL ---
# docker compose --profile db --profile redis --profile otel up -d
# EVENT_CONSUMER=redis
# EVENT_REDIS_URL=redis://localhost:6379/0
# OTEL_ENABLED=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
