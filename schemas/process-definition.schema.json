{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/monoposer/lowcode-bpmn/schemas/process-definition.schema.json",
  "title": "BPMN Process Definition (JSON IR)",
  "description": "Internal JSON IR aligned with BPMN 2.0. File storage and interchange use .bpmn20.xml; deploy API also accepts Content-Type: application/xml.",
  "type": "object",
  "required": ["id", "elements", "flows"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Process identifier (often same as deploy key)"
    },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "elements": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/element" }
    },
    "flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/sequenceFlow" }
    },
    "laneSet": {
      "type": "array",
      "items": { "$ref": "#/$defs/lane" }
    },
    "dataObjects": {
      "type": "array",
      "items": { "$ref": "#/$defs/dataObject" }
    },
    "dataStores": {
      "type": "array",
      "items": { "$ref": "#/$defs/dataStore" }
    }
  },
  "$defs": {
    "elementKind": {
      "type": "string",
      "enum": [
        "startEvent",
        "endEvent",
        "userTask",
        "scriptTask",
        "serviceTask",
        "sendTask",
        "receiveTask",
        "businessRuleTask",
        "exclusiveGateway",
        "parallelGateway",
        "inclusiveGateway",
        "subProcess",
        "boundaryEvent",
        "intermediateCatchEvent",
        "intermediateThrowEvent",
        "eventBasedGateway",
        "complexGateway",
        "callActivity"
      ]
    },
    "eventDefinitionType": {
      "type": "string",
      "enum": ["none", "message", "signal", "timer", "conditional", "error"],
      "description": "BPMN 2.0 start event definition type"
    },
    "eventDefinition": {
      "type": "object",
      "description": "BPMN 2.0 eventDefinition on startEvent — NOT a sequenceFlow condition",
      "additionalProperties": false,
      "properties": {
        "type": { "$ref": "#/$defs/eventDefinitionType" },
        "messageRef": {
          "type": "string",
          "description": "messageEventDefinition — canonical message name (e.g. airtable.orders.updated)"
        },
        "signalRef": {
          "type": "string",
          "description": "signalEventDefinition — broadcast signal name"
        },
        "correlationKey": {
          "type": "string",
          "description": "Dot path in trigger variables mapped to process instance businessKey"
        },
        "condition": {
          "type": "string",
          "description": "conditionalEventDefinition — expression evaluated against trigger payload before start"
        },
        "timerCycle": {
          "type": "string",
          "description": "timerEventDefinition — ISO-8601 repeat or cron; external scheduler invokes start/trigger"
        },
        "errorRef": {
          "type": "string",
          "description": "errorEventDefinition — error code for boundary events"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "type": { "const": "message" } },
            "required": ["type"]
          },
          "then": { "required": ["messageRef"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "signal" } },
            "required": ["type"]
          },
          "then": { "required": ["signalRef"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "timer" } },
            "required": ["type"]
          },
          "then": { "required": ["timerCycle"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "conditional" } },
            "required": ["type"]
          },
          "then": { "required": ["condition"] }
        },
        {
          "if": {
            "properties": { "type": { "const": "error" } },
            "required": ["type"]
          },
          "then": { "required": ["errorRef"] }
        }
      ]
    },
    "multiInstanceLoopCharacteristics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "isSequential": { "type": "boolean" },
        "collection": { "type": "string" },
        "elementVariable": { "type": "string" }
      }
    },
    "lane": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" },
        "flowNodeRefs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "dataObject": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" }
      }
    },
    "dataStore": {
      "type": "object",
      "required": ["id"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string" }
      }
    },
    "element": {
      "type": "object",
      "required": ["id", "type"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "$ref": "#/$defs/elementKind" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "assignees": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assigneesVariable": {
          "type": "string",
          "description": "Dot path in instance variables; overrides assignees at userTask activation"
        },
        "approvalMode": {
          "type": "string",
          "enum": ["any", "all", "sequential", "或签", "会签", "顺签"]
        },
        "requiredApprovals": { "type": "integer", "minimum": 1 },
        "returnTo": { "type": "string" },
        "onReject": { "type": "string", "enum": ["return", "terminateScope"] },
        "scopeId": { "type": "string" },
        "entryRef": { "type": "string" },
        "exitRef": { "type": "string" },
        "script": { "type": "string" },
        "scriptLang": { "type": "string" },
        "taskType": { "type": "string", "description": "Business subtype (extensionElements in XML)" },
        "implementation": { "type": "string", "description": "serviceTask implementation hint" },
        "serviceUrl": { "type": "string" },
        "serviceMethod": { "type": "string" },
        "messageRef": { "type": "string", "description": "sendTask/receiveTask message name" },
        "decisionRef": { "type": "string", "description": "businessRuleTask decision reference" },
        "autoComplete": { "type": "boolean" },
        "eventDefinition": { "$ref": "#/$defs/eventDefinition" },
        "attachedToRef": { "type": "string", "description": "boundaryEvent host activity id" },
        "cancelActivity": { "type": "boolean" },
        "calledElement": { "type": "string", "description": "callActivity target process key" },
        "multiInstance": { "$ref": "#/$defs/multiInstanceLoopCharacteristics" },
        "laneRef": { "type": "string" },
        "dataInputRefs": { "type": "array", "items": { "type": "string" } },
        "dataOutputRefs": { "type": "array", "items": { "type": "string" } },
        "formKey": { "type": "string", "description": "external form designer key" },
        "formUrl": { "type": "string", "description": "external form rendering URL" },
        "extensionHandler": { "type": "string", "description": "explicit plugin adapter id" },
        "eventSubProcess": { "type": "boolean" },
        "properties": { "type": "object" }
      }
    },
    "sequenceFlow": {
      "type": "object",
      "required": ["id", "sourceRef", "targetRef"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "sourceRef": { "type": "string" },
        "targetRef": { "type": "string" },
        "name": { "type": "string" },
        "condition": {
          "type": "string",
          "description": "Evaluated when leaving a gateway (exclusive/inclusive); ignored on linear edges"
        },
        "isDefault": { "type": "boolean" }
      }
    }
  }
}
